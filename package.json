{
  "name": "purse",
  "version": "0.1.0",
  "description": "A policy layer in front of your AI agent's payments. Set spending limits, require human approval over a threshold, and get a tamper-evident log of every decision. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "demo": "tsx examples/demo-agent.ts",
    "test": "tsx test/policy.test.ts",
    "mcp": "tsx src/mcp.ts"
  },
  "keywords": [
    "ai", "agents", "llm", "payments", "policy", "guardrails",
    "spending", "mcp", "x402", "governance", "agentic", "fintech"
  ],
  "license": "MIT",
  "author": "Oluwasegun Araba (ARABA)",
  "repository": { "type": "git", "url": "https://github.com/ArabianAnalyst/purse" },
  "engines": { "node": ">=18" },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  }
}
